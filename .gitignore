# 🔐 CRITICAL SECURITY (DO NOT COMMIT)

# All env files (already added but keep explicit)
.env
.env.*
!.env.example

# Local databases / backups
*.sqlite
*.db
*.sql
*.dump

# Logs (can leak data)
logs/
*.log

# Uploads / media (Cloudinary handles storage)
public/uploads/
public/temp/
uploads/

# OS / hidden sensitive files
Thumbs.db
desktop.ini

# IDE / local configs
.vscode/
.idea/

# Certificates / keys
*.key
*.crt
*.csr

# API / secret configs (if created later)
config/secrets.*
config/private.*

# Cache
.cache/
.tmp/
node_modules
